use bevy_ecs::prelude::*;
use anvilkit_core::math::Transform;
use anvilkit_ecs::physics::DeltaTime;
use anvilkit_input::prelude::{InputState, KeyCode};
use anvilkit_render::plugin::CameraComponent;

use crate::components::FpsCamera;
use crate::resources::{GameConfig, CameraLook};

#[derive(Debug, Default, Resource)]
pub struct WindowSize {
    pub width: f32,
    pub height: f32,
}

/// FPS camera movement: WASD moves on the XZ plane, mouse rotates view.
///
/// Mouse delta is read from `InputState::mouse_delta()`, which the engine
/// populates automatically from `DeviceEvent::MouseMotion`.
pub fn fps_camera_system(
    dt: Res<DeltaTime>,
    input: Res<InputState>,
    config: Res<GameConfig>,
    mut look: ResMut<CameraLook>,
    mut query: Query<(&mut Transform, &CameraComponent), With<FpsCamera>>,
) {
    let mouse_delta = input.mouse_delta();
    // Mouse look
    look.yaw += mouse_delta.x * config.mouse_sensitivity;
    look.pitch = (look.pitch - mouse_delta.y * config.mouse_sensitivity)
        .clamp(-1.5, 1.5);

    let rotation = glam::Quat::from_rotation_y(look.yaw)
        * glam::Quat::from_rotation_x(look.pitch);

    // WASD movement relative to camera yaw (ignore pitch for movement)
    let forward = glam::Quat::from_rotation_y(look.yaw) * glam::Vec3::Z;
    let right = glam::Quat::from_rotation_y(look.yaw) * glam::Vec3::X;

    let mut dir = glam::Vec3::ZERO;
    if input.is_key_pressed(KeyCode::W) { dir += forward; }
    if input.is_key_pressed(KeyCode::S) { dir -= forward; }
    if input.is_key_pressed(KeyCode::A) { dir -= right; }
    if input.is_key_pressed(KeyCode::D) { dir += right; }

    if dir.length_squared() > 0.0 {
        dir = dir.normalize();
    }

    for (mut transform, _cam) in query.iter_mut() {
        transform.translation += dir * config.move_speed * dt.0;
        transform.rotation = rotation;
    }
}
